{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xDB",
  "version": "1.0.29",
  "identifier": "com.alan.xDB",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "xDB",
        "width": 1000,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:xDB.sqlite"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzRjAxRTU5MkVEMjhCREIKUldUYmk5SXVXUjd3TTMrN3dhazZzYU9TQXVYMCtVb2dudnRwSFJKMzgrdE82OEhIdG1vMmU1YU4K",
      "endpoints": [
        "https://github.com/cuigaoshun/xDB/releases/latest/download/latest.json"
      ]
    }
  }
}
